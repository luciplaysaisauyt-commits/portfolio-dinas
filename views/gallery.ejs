<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DIN – Gallery</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=DM+Sans:wght@200;300;400;500&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/style.css">
  <link rel="stylesheet" href="/assets/css/gallery.css">
  <link rel="icon" type="image/png" href="/assets/DIN.png">
</head>
<body>

<!-- CUSTOM CURSOR -->
<div class="din-cursor" id="dinCursor"></div>
<div class="din-cursor-ring" id="dinCursorRing"></div>

<%- include('partials/header') %>

<!-- HERO -->
<section class="gl-hero">
  <div class="gl-hero-inner">
    <p class="gl-eyebrow fu">Portfolio · All Projects</p>
    <h1 class="fu fd1">All<br><em>Work</em></h1>
    <p class="gl-sub fu fd2">
      A curated selection of interfaces, clones and concept projects — documenting my journey in design &amp; development.
    </p>
  </div>
  <div class="gl-hero-count fu fd3">
    <span class="gl-count-n">11</span>
    <span class="gl-count-l">Projects</span>
  </div>
</section>

<!-- PROJECTS LIST — same card style as Home -->
<section class="gl-works">
  <div class="gl-works-head">
    <span class="label-tag">Selected Work</span>
  </div>

  <div class="gl-track-wrap" id="glWrap">
    <div class="gl-track" id="glTrack">


      <article class="wcard" data-href="/portfolio/clm">
        <div class="wcard-bg wbg7">
          <div class="wcard-mock">
            <div class="wmock-bar"><span></span><span></span><span></span></div>
            <div class="wmock-body"><div class="ml a"></div><div class="ml l"></div><div class="ml m"></div><div class="ml s"></div></div>
          </div>
        </div>
        <div class="wcard-veil"></div>
        <div class="wcard-num">01</div>
        <div class="wcard-foot">
          <div class="wcard-cat">UI UX Redesign</div>
          <h3 class="wcard-title">CLM<br>Mafia Platform</h3>
        </div>
        <div class="wcard-reveal">
          <p>Full redesign of Mafia platform with ratings, tournaments, clubs and admin panel.</p>
          <div class="rtags"><span>Figma</span><span>Design System</span><span>Case Study</span></div>
          <div class="rlink">Open case study <div class="rarrow"><svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10"/></svg></div></div>
        </div>
      </article>


      <article class="wcard" data-href="/portfolio/unnie-box">
        <div class="wcard-bg wbg6">
          <div class="wcard-mock">
            <div class="wmock-bar"><span></span><span></span><span></span></div>
            <div class="wmock-body"><div class="ml a"></div><div class="ml l"></div><div class="ml s"></div><div class="ml m"></div></div>
          </div>
        </div>
        <div class="wcard-veil"></div>
        <div class="wcard-num">04</div>
        <div class="wcard-foot">
          <div class="wcard-cat">UI UX Design</div>
          <h3 class="wcard-title">Unnie Box<br>Landing Page</h3>
        </div>
        <div class="wcard-reveal">
          <p>Korean beauty subscription box landing page focused on trust, conversion, and delight.</p>
          <div class="rtags"><span>Figma</span><span>UI Kit</span><span>Landing</span></div>
          <div class="rlink">Open case study <div class="rarrow"><svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10"/></svg></div></div>
        </div>
      </article>

    </div>
  </div>



<!-- FOOTER -->
<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__col site-footer__col--brand">
      <img src="/assets/DIN.png" alt="DIN Logo" class="site-footer__logo-img">
      <p class="site-footer__tagline">Creative designer &amp; developer crafting digital experiences that matter.</p>
    </div>
    <div class="site-footer__col">
      <p class="site-footer__col-title">Navigation</p>
      <nav class="site-footer__nav">
        <a href="/">Home</a><a href="/gallery">Gallery</a>
        <a href="/about">About</a><a href="/contact">Contact</a>
      </nav>
    </div>
    <div class="site-footer__col">
      <p class="site-footer__col-title">Contact</p>
      <div class="site-footer__item">din.design.studio@gmail.com</div>
      <div class="site-footer__item">Canada</div>
    </div>
    <div class="site-footer__col">
      <p class="site-footer__col-title">Newsletter</p>
      <p class="site-footer__form-label">Stay updated with new projects.</p>
      <form class="site-footer__form" id="newsletterForm">
        <input type="email" placeholder="your@email.com">
        <button type="submit">Subscribe</button>
      </form>
    </div>
  </div>
  <div class="site-footer__bottom">
    <span>© 2025 DIN. All rights reserved.</span>
    <span>Designed &amp; built with care</span>
  </div>
</footer>

<script src="/assets/js/main.js" defer></script>
<script src="/assets/js/gallery.js" defer></script>
</body>
</html>
