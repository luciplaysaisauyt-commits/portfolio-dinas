<%
  const footerTheme = (typeof theme !== "undefined" && theme) ? theme : "default"
  const caseLabel = (typeof caseName !== "undefined" && caseName) ? caseName : (project && project.title ? project.title : "Case Study")
%>

<footer class="case-footer <%= footerTheme ? `case-footer--${footerTheme}` : "" %>">
  <div class="case-footer__inner">
    <div class="case-footer__brand">
      <img src="/assets/DIN.png" alt="DIN Logo" class="case-footer__logo">
      <p class="case-footer__tagline">Creative designer crafting digital experiences that matter.</p>
    </div>

    <div class="case-footer__col">
      <p class="case-footer__title">Navigation</p>
      <nav class="case-footer__nav">
        <a href="/">Home</a>
        <a href="/gallery">Gallery</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </nav>
    </div>

    <div class="case-footer__col">
      <p class="case-footer__title">Contact</p>
      <div class="case-footer__item">din.design.studio@gmail.com</div>
      <div class="case-footer__item">Canada</div>
    </div>

    <div class="case-footer__col">
      <p class="case-footer__title">Newsletter</p>
      <p class="case-footer__hint">Stay updated with new projects.</p>

      <form class="case-footer__form" onsubmit="caseSubscribe(this); return false;">
        <label class="sr-only" for="caseNewsletterEmail">Email</label>
        <input id="caseNewsletterEmail" name="email" type="email" placeholder="your@email.com" autocomplete="email">
        <button type="submit">Subscribe</button>
      </form>
    </div>
  </div>

  <div class="case-footer__bottom">
    <span>© 2025 DIN. All rights reserved.</span>

    <span class="case-footer__case-label"><%= caseLabel %> · UI UX Case Study</span>

    <div class="case-footer__proj-nav">
      <% if (nav && nav.prev) { %>
        <a href="/portfolio/<%= nav.prev.slug %>">← Prev</a>
      <% } %>

      <a href="/gallery">All projects</a>
      <a class="cta" href="/contact">Hire me →</a>

      <% if (nav && nav.next) { %>
        <a href="/portfolio/<%= nav.next.slug %>">Next →</a>
      <% } %>
    </div>
  </div>
</footer>