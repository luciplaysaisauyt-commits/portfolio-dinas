<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DIN – <%= project.title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=DM+Sans:wght@200;300;400;500&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/style.css">
  <link rel="stylesheet" href="/assets/css/portfolio.css">
  <link rel="icon" type="image/png" href="/assets/DIN.png">
</head>
<body>

<%- include('partials/header') %>

<!-- CASE NAV -->
<div class="case-nav" role="navigation" aria-label="Project navigation">
  <a class="case-nav__back" href="/gallery">Back to gallery</a>
  <div class="case-nav__spacer"></div>
  <% if (typeof nav !== 'undefined' && nav && nav.prev) { %>
    <a class="case-nav__link" href="/portfolio/<%= nav.prev.slug %>">Prev</a>
  <% } %>
  <% if (typeof nav !== 'undefined' && nav && nav.next) { %>
    <a class="case-nav__link" href="/portfolio/<%= nav.next.slug %>">Next</a>
  <% } %>
</div>


<!-- BREADCRUMB -->
<div class="pf-breadcrumb">
  <a href="/">Home</a><span>/</span>
  <a href="/gallery">Gallery</a><span>/</span>
  <span><%= project.title %></span>
</div>

<!-- HERO -->
<section class="pf-hero">
  <div class="pf-meta-row fu">
    <span class="pf-cat"><%= project.category %></span>
    <span class="pf-year"><%= project.year %></span>
  </div>
  <h1 class="fu fd1"><%= project.title %></h1>
  <p class="pf-tagline fu fd2"><%= project.tagline %></p>
  <div class="pf-tags fu fd3">
    <% project.tags.forEach(tag => { %><span><%= tag %></span><% }); %>
  </div>
</section>

<!-- OVERVIEW STRIP -->
<div class="pf-overview">
  <div class="pf-ov-item">
    <span class="pf-ov-l">Role</span>
    <span class="pf-ov-v"><%= project.role %></span>
  </div>
  <div class="pf-ov-item">
    <span class="pf-ov-l">Duration</span>
    <span class="pf-ov-v"><%= project.duration %></span>
  </div>
  <div class="pf-ov-item">
    <span class="pf-ov-l">Tools</span>
    <span class="pf-ov-v"><%= project.tools %></span>
  </div>
  <div class="pf-ov-item">
    <span class="pf-ov-l">Year</span>
    <span class="pf-ov-v"><%= project.year %></span>
  </div>
</div>

<!-- BODY -->
<main class="pf-body">

  <section class="pf-sec fu">
    <div class="pf-sec-label">01 — Challenge</div>
    <div class="pf-sec-content">
      <h2><%= project.challenge.title %></h2>
      <p><%= project.challenge.text %></p>
    </div>
  </section>

  <section class="pf-sec fu">
    <div class="pf-sec-label">02 — Process</div>
    <div class="pf-sec-content">
      <h2><%= project.process.title %></h2>
      <p><%= project.process.text %></p>
      <% if (project.process.steps) { %>
      <div class="pf-steps">
        <% project.process.steps.forEach((s, i) => { %>
        <div class="pf-step">
          <div class="pf-step-n">0<%= i+1 %></div>
          <div>
            <strong><%= s.name %></strong>
            <p><%= s.desc %></p>
          </div>
        </div>
        <% }); %>
      </div>
      <% } %>
    </div>
  </section>

  <section class="pf-sec fu">
    <div class="pf-sec-label">03 — Results</div>
    <div class="pf-sec-content">
      <h2><%= project.results.title %></h2>
      <p><%= project.results.text %></p>
      <% if (project.results.metrics) { %>
      <div class="pf-metrics">
        <% project.results.metrics.forEach(m => { %>
        <div class="pf-metric">
          <span class="pf-metric-v"><%= m.value %></span>
          <span class="pf-metric-l"><%= m.label %></span>
        </div>
        <% }); %>
      </div>
      <% } %>
    </div>
  </section>

  <section class="pf-sec fu">
    <div class="pf-sec-label">04 — Learnings</div>
    <div class="pf-sec-content">
      <h2><%= project.learnings.title %></h2>
      <p><%= project.learnings.text %></p>
    </div>
  </section>

</main>

<!-- NEXT PROJECT -->
<section class="pf-next">
  <span class="pf-next-label">Next Project</span>
  <a href="/portfolio/<%= (typeof nav !== 'undefined' && nav && nav.next ? nav.next.slug : project.next.slug) %>" class="pf-next-link">
    <span class="pf-next-title"><%= (typeof nav !== 'undefined' && nav && nav.next ? nav.next.title : project.next.title) %></span>
    <div class="pf-next-arrow">
      <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 17L17 7M17 7H7M17 7v10"/>
      </svg>
    </div>
  </a>
</section>

<!-- FOOTER -->
<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__col site-footer__col--brand">
      <img src="/assets/DIN.png" alt="DIN Logo" class="site-footer__logo-img">
      <p class="site-footer__tagline">Creative designer &amp; developer crafting digital experiences.</p>
    </div>
    <div class="site-footer__col">
      <p class="site-footer__col-title">Navigation</p>
      <nav class="site-footer__nav">
        <a href="/">Home</a><a href="/gallery">Gallery</a>
        <a href="/about">About</a><a href="/contact">Contact</a>
      </nav>
    </div>
    <div class="site-footer__col">
      <p class="site-footer__col-title">Contact</p>
      <div class="site-footer__item">din.design.studio@gmail.com</div>
      <div class="site-footer__item">Canada</div>
    </div>
  </div>
  <div class="site-footer__bottom">
    <span>© 2025 DIN. All rights reserved.</span>
    <span>Designed &amp; built with care</span>
  </div>
</footer>

<script src="/assets/js/main.js" defer></script>
</body>
</html>
